{
  "rewrites": [
    { "source": "/", "destination": "/api/index" },
    { "source": "/api/block/:height", "destination": "/api/block/[height]" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, s-maxage=60, stale-while-revalidate=120" }
      ]
    }
  ]
}
